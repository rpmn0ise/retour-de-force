---
layout: layouts/base.njk
lang: fr
permalink: /assetto/index.html
---
{% set mods = collections.assetto %}

<section class="page-hero">
  <p class="page-hero-tag">// assetto corsa</p>
  <h1><span class="game-assetto">Assetto Corsa</span> Mods</h1>
  <p class="page-hero-sub" data-i18n="assetto_sub">Voitures, circuits, skins et configs vérifiés.</p>
  <span class="mod-count-badge"><strong>{{ mods.length }}</strong> <span data-i18n="mods_available">mods disponibles</span></span>
</section>

<div class="mod-toolbar">
  <div class="search-wrap">
    <span class="search-icon">⌕</span>
    <input class="search-input" id="modSearch" type="search" data-i18n-placeholder="search_placeholder" autocomplete="off" />
  </div>
  <div class="filter-group">
    <span class="filter-label" data-i18n="filter_category"></span>
    <button class="filter-btn active" data-filter-type="game" data-filter-value="all" data-i18n="filter_all"></button>
    {% for cat in site.categories.assetto %}
      <button class="filter-btn" data-filter-type="tag" data-filter-value="{{ cat | lower }}">{{ cat }}</button>
    {% endfor %}
  </div>
  <select class="sort-select" id="modSort">
    <option value="date" data-i18n="sort_date"></option>
    <option value="name" data-i18n="sort_name"></option>
  </select>
</div>

<div class="mods-grid">
  {% for mod in mods %}
    {% include "partials/mod-card.njk" %}
  {% endfor %}
  <div class="no-results hidden" id="noResults">
    <div class="no-results-icon">⊘</div>
    <span data-i18n="no_results"></span>
  </div>
</div>
