---
layout: layouts/base.njk
lang: fr
---
{% set t = i18n[lang | default('fr')] %}
{% set allMods = collections.mods %}

<section class="page-hero">
  <p class="page-hero-tag">// Retour de Force</p>
  <h1>
    <span data-i18n="hero_title_1">Mods vérifiés pour</span><br/>
    <span class="game-beamng">BeamNG</span> &amp; <span class="game-assetto">Assetto Corsa</span>
  </h1>
  <p class="page-hero-sub" data-i18n="site_tagline"></p>
  <span class="mod-count-badge">
    <strong>{{ allMods.length }}</strong> <span data-i18n="mods_available">mods disponibles</span>
  </span>
</section>

<div class="mod-toolbar">
  <div class="search-wrap">
    <span class="search-icon">⌕</span>
    <input class="search-input" id="modSearch" type="search" data-i18n-placeholder="search_placeholder" autocomplete="off" />
  </div>

<div class="filter-group">
    <span class="filter-label" data-i18n="filter_author"></span>
    <button class="filter-btn active" data-filter-type="author" data-filter-value="all" data-i18n="filter_all"></button>
    {% set seenAuthors = [] %}
    {% for mod in allMods %}
      {% if mod.data.author and mod.data.author not in seenAuthors %}
        {% set seenAuthors = (seenAuthors.push(mod.data.author), seenAuthors) %}
        <button class="filter-btn" data-filter-type="author" data-filter-value="{{ mod.data.author | lower }}">{{ mod.data.author }}</button>
      {% endif %}
    {% endfor %}
  </div>

  <div class="filter-group">
    <span class="filter-label" data-i18n="filter_category"></span>
    {% set seen = [] %}
    {% for mod in allMods %}
      {% if mod.data.category and mod.data.category not in seen %}
        {% set seen = (seen.push(mod.data.category), seen) %}
        <button class="filter-btn" data-filter-type="tag" data-filter-value="{{ mod.data.category | lower }}">{{ mod.data.category }}</button>
      {% endif %}
    {% endfor %}
  </div>

  <select class="sort-select" id="modSort">
    <option value="date" data-i18n="sort_date"></option>
    <option value="name" data-i18n="sort_name"></option>
  </select>
</div>

<div class="mods-grid">
  {% for mod in allMods %}
    {% include "partials/mod-card.njk" %}
  {% endfor %}
  <div class="no-results hidden" id="noResults">
    <div class="no-results-icon">⊘</div>
    <span data-i18n="no_results"></span>
  </div>
</div>
