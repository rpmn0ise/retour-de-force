<!DOCTYPE html>
<html lang="{{ lang | default('fr') }}" data-theme="dark" data-lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} — {% endif %}{{ site.site_name }}</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}{{ i18n[lang | default('fr')].site_tagline }}{% endif %}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,400&family=Syne:wght@400;500;600;700;800&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{ '/assets/css/main.css' | url }}" />
  <link rel="icon" href="{{ '/assets/icons/favicon.svg' | url }}" type="image/svg+xml" />
</head>
<body>

<header class="site-header">
  <nav class="nav-inner">
    <a href="{{ '/' | url }}" class="logo">
      <span class="logo-mark">▸</span>
      <span class="logo-text">{{ site.site_name }}</span>
    </a>

    <ul class="nav-links" id="navLinks">
      <li><a href="{{ '/' | url }}"        class="nav-link {% if page.url == '/' %}active{% endif %}"      data-i18n="nav_home"></a></li>
      <li><a href="{{ '/beamng/' | url }}" class="nav-link {% if '/beamng' in page.url %}active{% endif %}" data-i18n="nav_beamng"></a></li>
      <li><a href="{{ '/assetto/' | url }}" class="nav-link {% if '/assetto' in page.url %}active{% endif %}" data-i18n="nav_assetto"></a></li>
      <li><a href="{{ '/nouveautes/' | url }}" class="nav-link {% if '/nouveautes' in page.url %}active{% endif %}" data-i18n="nav_nouveautes"></a></li>
      <li><a href="{{ '/soumettre/' | url }}" class="nav-link {% if '/soumettre' in page.url %}active{% endif %}" data-i18n="nav_soumettre"></a></li>
      <li><a href="{{ '/stats/' | url }}" class="nav-link {% if '/stats' in page.url %}active{% endif %}" data-i18n="nav_stats"></a></li>
      <li><a href="{{ '/about/' | url }}"  class="nav-link {% if page.url == '/about/' %}active{% endif %}" data-i18n="nav_about"></a></li>
    </ul>

    <div class="nav-controls">
      <button class="ctrl-btn" id="langToggle" title="Switch language" data-i18n="toggle_lang"></button>
      <button class="ctrl-btn theme-toggle" id="themeToggle" aria-label="Toggle theme">
        <span class="icon-sun">☀</span>
        <span class="icon-moon">◑</span>
      </button>
      <button class="nav-burger" id="navBurger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>
</header>

<main class="site-main">
  {{ content | safe }}
</main>

<footer class="site-footer">
  <div class="footer-inner">
    <span class="footer-logo">{{ site.site_name }}</span>
    <p class="footer-text" data-i18n="footer_text"></p>
    <span class="footer-badge">
      <span class="badge-dot"></span> Discord-verified
    </span>
  </div>
</footer>

<script>
  window.I18N = {{ i18n | jsonify | safe }};
</script>
<script src="{{ '/assets/js/main.js' | url }}"></script>
</body>
</html>
