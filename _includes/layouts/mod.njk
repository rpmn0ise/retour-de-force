---
layout: layouts/base.njk
---
{% set t = i18n[lang | default('fr')] %}

<div class="mod-detail">

  <a href="javascript:history.back()" class="detail-back">{{ t.detail_back }}</a>

  <div class="detail-header">
    <div>
      <p class="detail-tag">
        {% if game === 'beamng' %}BeamNG.drive{% else %}Assetto Corsa{% endif %}
        {% if category %} · {{ category }}{% endif %}
      </p>
      <h1 class="detail-title">{{ title }}</h1>
    </div>
    <span class="card-game-badge badge-{{ game }}" style="position:relative;top:0;left:0;align-self:start;flex-shrink:0;">
      {% if game === 'beamng' %}BeamNG{% else %}Assetto{% endif %}
    </span>
  </div>

  <div class="detail-meta-grid">
    {% if author %}
    <div class="detail-meta-item">
      <span class="detail-meta-label">{{ t.card_author }}</span>
      <span class="detail-meta-value">{{ author }}</span>
    </div>
    {% endif %}
    {% if version %}
    <div class="detail-meta-item">
      <span class="detail-meta-label">{{ t.card_version }}</span>
      <span class="detail-meta-value">v{{ version }}</span>
    </div>
    {% endif %}
    {% if date %}
    <div class="detail-meta-item">
      <span class="detail-meta-label">{{ t.card_updated }}</span>
      <span class="detail-meta-value">{{ date | dateFormat }}</span>
    </div>
    {% endif %}
    {% if source %}
    <div class="detail-meta-item">
      <span class="detail-meta-label">{{ t.card_source }}</span>
      <span class="detail-meta-value">{{ source }}</span>
    </div>
    {% endif %}
    {% if tags %}
    <div class="detail-meta-item">
      <span class="detail-meta-label">{{ t.card_tags }}</span>
      <span class="detail-meta-value" style="display:flex;flex-wrap:wrap;gap:4px;">
        {% for tag in tags %}<span class="tag">{{ tag }}</span>{% endfor %}
      </span>
    </div>
    {% endif %}
  </div>

  {% if image %}
    <img class="detail-image" src="{{ image }}" alt="{{ title }}" />
  {% endif %}

  <!-- Boutons download + hotfix -->
  {% if download %}
  <div class="detail-download-bar">
    <div class="detail-download-buttons">
      <a href="{{ download }}" class="btn-download-main" target="_blank" rel="noopener">
        ↓ {{ t.detail_download }} <span class="btn-version">v{{ version }}</span>
      </a>
      {% if hotfix %}
      <a href="{{ hotfix }}" class="btn-hotfix" target="_blank" rel="noopener">
        ⚡ Hotfix
      </a>
      {% endif %}
    </div>
    {% if source %}
    <span class="detail-source-value">{{ source }}</span>
    {% endif %}
  </div>
  {% endif %}

  <!-- Historique des versions -->
  {% if changelog %}
  <div class="changelog-section">
    <h2 class="changelog-title" data-i18n="changelog_title">Historique des versions</h2>
    <div class="changelog-list">
      {% for entry in changelog %}
      <div class="changelog-entry {% if loop.first %}changelog-entry--latest{% endif %}">
        <div class="changelog-entry-left">
          {% if loop.first %}
            <span class="changelog-badge">latest</span>
          {% endif %}
          <span class="changelog-version">v{{ entry.version }}</span>
        </div>
        <a href="{{ entry.url }}" class="changelog-dl" target="_blank" rel="noopener">
          ↓ Télécharger
        </a>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <div class="detail-body">
    {{ content | safe }}
  </div>

</div>
