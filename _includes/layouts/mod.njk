---
layout: layouts/base.njk
---
{% set t = i18n[lang | default('fr')] %}

<div class="mod-detail">

  <a href="javascript:history.back()" class="detail-back">{{ t.detail_back }}</a>

  <div class="detail-header">
    <div>
      <p class="detail-tag">
        BeamNG.drive
        {% if category %} · {{ category }}{% endif %}
      </p>
      <h1 class="detail-title">{{ title }}</h1>
    </div>

  </div>

  <div class="detail-meta-grid">
    {% if author %}
    <div class="detail-meta-item">
      <span class="detail-meta-label">{{ t.card_author }}</span>
      <span class="detail-meta-value">{{ author }}</span>
    </div>
    {% endif %}
    {% if version %}
    <div class="detail-meta-item">
      <span class="detail-meta-label">{{ t.card_version }}</span>
      <span class="detail-meta-value">v{{ version }}</span>
    </div>
    {% endif %}
    {% if date %}
    <div class="detail-meta-item">
      <span class="detail-meta-label">{{ t.card_updated }}</span>
      <span class="detail-meta-value">{{ date | dateFormat }}</span>
    </div>
    {% endif %}
    {% if source %}
    <div class="detail-meta-item">
      <span class="detail-meta-label">{{ t.card_source }}</span>
      <span class="detail-meta-value">{{ source }}</span>
    </div>
    {% endif %}
    {% if tags %}
    <div class="detail-meta-item">
      <span class="detail-meta-label">{{ t.card_tags }}</span>
      <span class="detail-meta-value" style="display:flex;flex-wrap:wrap;gap:4px;">
        {% for tag in tags %}<span class="tag">{{ tag }}</span>{% endfor %}
      </span>
    </div>
    {% endif %}
  </div>

  <!-- Galerie (images: [...]) ou image unique -->
  {% if images and images.length > 0 %}
    {% set allImages = [image] if image else [] %}
    {% for img in images %}
      {% set allImages = (allImages.push(img), allImages) %}
    {% endfor %}

    <div class="mod-gallery">
      <!-- Image principale cliquable -->
      <div class="gallery-main" onclick="openLightbox(0)">
        <img src="{{ allImages[0] }}" alt="{{ title }} — 1" loading="lazy" />
        {% if allImages.length > 1 %}
          <span class="gallery-count-badge">{{ allImages.length }} photos</span>
        {% endif %}
        <span class="gallery-zoom-hint">⊕</span>
      </div>
      <!-- Miniatures (2ème image et suivantes) -->
      {% if allImages.length > 1 %}
      <div class="gallery-thumbs">
        {% for img in allImages %}
          {% if not loop.first %}
          <div class="gallery-thumb" onclick="openLightbox({{ loop.index0 }})">
            <img src="{{ img }}" alt="{{ title }} — {{ loop.index }}" loading="lazy" />
          </div>
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}
    </div>

    <!-- Lightbox -->
    <div class="lightbox" id="lightbox" onclick="closeLightbox(event)">
      <button class="lightbox-close" onclick="closeLightbox()">×</button>
      <button class="lightbox-prev" onclick="lightboxNav(-1, event)">‹</button>
      <button class="lightbox-next" onclick="lightboxNav(1, event)">›</button>
      <div class="lightbox-inner">
        <img id="lightboxImg" src="" alt="" />
        <span class="lightbox-counter" id="lightboxCounter"></span>
      </div>
    </div>

    <script>
    const GALLERY_IMGS = {{ allImages | jsonify | safe }};
    let currentIdx = 0;

    function openLightbox(idx) {
      currentIdx = idx;
      updateLightbox();
      document.getElementById('lightbox').classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeLightbox(e) {
      if (e && e.target !== document.getElementById('lightbox') && !e.target.classList.contains('lightbox-close')) return;
      document.getElementById('lightbox').classList.remove('open');
      document.body.style.overflow = '';
    }
    function lightboxNav(dir, e) {
      if (e) e.stopPropagation();
      currentIdx = (currentIdx + dir + GALLERY_IMGS.length) % GALLERY_IMGS.length;
      updateLightbox();
    }
    function updateLightbox() {
      const img = document.getElementById('lightboxImg');
      img.style.opacity = '0';
      setTimeout(() => {
        img.src = GALLERY_IMGS[currentIdx];
        img.style.opacity = '1';
      }, 100);
      document.getElementById('lightboxCounter').textContent = (currentIdx + 1) + ' / ' + GALLERY_IMGS.length;
    }
    document.addEventListener('keydown', e => {
      const lb = document.getElementById('lightbox');
      if (!lb.classList.contains('open')) return;
      if (e.key === 'ArrowLeft')  lightboxNav(-1);
      if (e.key === 'ArrowRight') lightboxNav(1);
      if (e.key === 'Escape')     { lb.classList.remove('open'); document.body.style.overflow = ''; }
    });
    </script>

  {% elif image %}
    <img class="detail-image" src="{{ image }}" alt="{{ title }}" onclick="openSingleLightbox()" style="cursor:zoom-in;" />

    <!-- Lightbox image unique -->
    <div class="lightbox" id="lightbox" onclick="closeLightbox(event)">
      <button class="lightbox-close" onclick="closeLightbox()">×</button>
      <div class="lightbox-inner">
        <img id="lightboxImg" src="{{ image }}" alt="{{ title }}" />
      </div>
    </div>

    <script>
    const GALLERY_IMGS = ["{{ image }}"];
    let currentIdx = 0;
    function openSingleLightbox() {
      document.getElementById('lightboxImg').src = "{{ image }}";
      document.getElementById('lightbox').classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeLightbox(e) {
      if (e && e.target !== document.getElementById('lightbox') && !e.target.classList.contains('lightbox-close')) return;
      document.getElementById('lightbox').classList.remove('open');
      document.body.style.overflow = '';
    }
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') { document.getElementById('lightbox').classList.remove('open'); document.body.style.overflow = ''; }
    });
    </script>
  {% endif %}

  <!-- Boutons download + hotfix -->
  {% if download %}
  <div class="detail-download-bar">
    <div class="detail-download-buttons">
      <a href="{{ download }}" class="btn-download-main" target="_blank" rel="noopener">
        ↓ {{ t.detail_download }} <span class="btn-version">v{{ version }}</span>
      </a>
      {% if hotfix %}
      <a href="{{ hotfix }}" class="btn-hotfix" target="_blank" rel="noopener">
        ⚡ Hotfix
      </a>
      {% endif %}
    </div>
    {% if source %}
    <span class="detail-source-value">{{ source }}</span>
    {% endif %}
  </div>
  {% endif %}

  <!-- Historique des versions -->
  {% if changelog %}
  <div class="changelog-section">
    <h2 class="changelog-title" data-i18n="changelog_title">Historique des versions</h2>
    <div class="changelog-list">
      {% for entry in changelog %}
      <div class="changelog-entry {% if loop.first %}changelog-entry--latest{% endif %}">
        <div class="changelog-entry-left">
          {% if loop.first %}
            <span class="changelog-badge">latest</span>
          {% endif %}
          <span class="changelog-version">v{{ entry.version }}</span>
        </div>
        <a href="{{ entry.url }}" class="changelog-dl" target="_blank" rel="noopener">
          ↓ Télécharger
        </a>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <div class="detail-body">
    {{ content | safe }}
  </div>

</div>
